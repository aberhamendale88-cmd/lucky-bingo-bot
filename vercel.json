{
  "version": 2,
  "builds": [
    {
      "src": "api/bot.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "source": "/api/bot",
      "dest": "api/bot.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "source": "/(.*)",
      "dest": "/index.html"
    }
  ]
}